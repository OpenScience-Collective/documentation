          {
            "type": "text",
            "content": "### They are massively, massively powerful.",
            "style": {
              "fontSize": "large",
              "fontWeight": "bold",
              "color": "#F59E0B"
            },
            "animation": { "fragment": true, "type": "fade", "index": 0 },
