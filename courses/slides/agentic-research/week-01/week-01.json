          },
          {
            "type": "code",
            "code": "# Install Homebrew\n/bin/bash -c \"$(curl -fsSL\n  https://raw.githubusercontent.com\n  /Homebrew/install/HEAD/install.sh)\"\n\n# Then install git and gh\nbrew install git gh",
