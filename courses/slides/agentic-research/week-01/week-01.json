            "style": { "fontSize": "xl" },
            "position": { "area": "header" }
          },
          {
            "type": "text",
            "content": "### Without guardrails",
            "style": {
              "fontSize": "large",
              "fontWeight": "bold",
              "color": "#EF4444"
            },
            "position": { "area": "left" }
          },
          {
            "type": "bullets",
            "items": [
              "AI generates code 10x faster",
              "Bugs accumulate 10x faster",
              "No audit trail",
              "\"It worked on my machine\"",
              "Can't reproduce last week's result"
            ],
            "bulletStyle": "disc",
            "style": { "fontSize": "large" },
            "animation": { "fragment": true, "type": "fade", "index": 0 },
            "position": { "area": "left", "order": 1 }
          },
          {
            "type": "text",
            "content": "### With version control",
            "style": {
              "fontSize": "large",
              "fontWeight": "bold",
              "color": "#059669"
            },
            "position": { "area": "right" }
          },
          {
            "type": "bullets",
            "items": [
              "AI generates code 10x faster",
              "Every change is tracked",
              "Full audit trail: who, what, when, why",
              "`git revert` is your undo button",
              "Tag a commit, reproduce the result forever"
            ],
            "bulletStyle": "disc",
            "style": { "fontSize": "large" },
            "animation": { "fragment": true, "type": "fade", "index": 1 },
            "position": { "area": "right", "order": 1 }
          }
        ],
        "speakerNotes": "Here is the problem. AI makes you faster. Without guardrails, you accumulate mistakes just as fast. With version control, every change is tracked, every mistake is reversible, and every result is reproducible."
      },
