            "type": "text",
            "content": "Four commands to navigate your filesystem:",
            "style": { "fontSize": "medium" },
            "position": { "area": "content" }
          },
          {
            "type": "code",
            "code": "pwd              # Where am I?\n\nls               # What's here?\n\ncd my-project    # Go somewhere\n\nmkdir new-folder # Create a directory",
